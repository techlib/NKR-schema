{
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "cordra": {
        "type": {
          "autoGeneratedField": "handle"
        }
      }
    },
    "handleUrl": {
      "type": "string",
      "format": "uri",
      "title": "Handle identifier",
      "description": "Persistent identifier for the record.",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "maxLength": 128,
      "title": "Name",
      "cordra": {
        "preview": {
          "showInPreview": true,
          "isPrimary": true
        }
      }
    },
    "person": {
      "type": "array",
      "title": "Persons",
      "description": "Person(s) associated with the repository. For affiliation, use freetext. For phone number, use the international format, e.g.+420 xxx xxx xxx. Select the appropriate role: project owner/garant, administrator/správce, data curator/datový kurátor, developer/vývojář, specialist/metodik.",
      "format": "table",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "title": "Person",
        "required": [
          "personName",
          "personRole"
        ],
        "properties": {
          "personName": {
            "title": "Name",
            "type": "string"
          },
          "personEmail": {
            "title": "Email",
            "type": "string",
            "format": "email"
          },
          "personPhone": {
            "title": "Phone number",
            "type": "string"
          },
          "personAffiliation": {
            "title": "Affiliation",
            "type": "string"
          },
          "personRole": {
            "title": "Role",
            "type": "string",
            "enum": [
              "data curator",
              "administrator",
              "project owner",
              "specialist",
              "developer",
              "other"
            ]
          }
        }
      }
    }
  }
